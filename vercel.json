{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index.js" },
    { "source": "/shopify-ecommerce-creative-marketing-agency-india", "destination": "/shopify-ecommerce-creative-marketing-agency-india/index.html" },
    { "source": "/shopify-ecommerce-creative-marketing-agency-india/", "destination": "/shopify-ecommerce-creative-marketing-agency-india/index.html" },
    { "source": "/affordable-social-media-management-for-startups-india", "destination": "/affordable-social-media-management-for-startups-india/index.html" },
    { "source": "/affordable-social-media-management-for-startups-india/", "destination": "/affordable-social-media-management-for-startups-india/index.html" },
    { "source": "/podcast-video-editing-services-comparison", "destination": "/podcast-video-editing-services-comparison/index.html" },
    { "source": "/podcast-video-editing-services-comparison/", "destination": "/podcast-video-editing-services-comparison/index.html" },
    { "source": "/improve-instagram-reels-engagement-brand", "destination": "/improve-instagram-reels-engagement-brand/index.html" },
    { "source": "/improve-instagram-reels-engagement-brand/", "destination": "/improve-instagram-reels-engagement-brand/index.html" },
    { "source": "/best-social-media-marketing-agency-small-business-india", "destination": "/best-social-media-marketing-agency-small-business-india/index.html" },
    { "source": "/best-social-media-marketing-agency-small-business-india/", "destination": "/best-social-media-marketing-agency-small-business-india/index.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Content-Security-Policy", "value": "default-src 'self'; base-uri 'self'; object-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com data:; img-src 'self' data: blob: https:; media-src 'self' blob: https:; connect-src 'self' https://api.web3forms.com; frame-src https://www.youtube.com https://www.youtube-nocookie.com; form-action 'self' https://api.web3forms.com; frame-ancestors 'self'; upgrade-insecure-requests" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=(), payment=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(js|css|woff2|woff|ttf|svg|webp|avif|png|jpg|jpeg|gif|ico|mp4)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
